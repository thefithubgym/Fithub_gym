model Testimonial {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String
  rating     Int
  review     String   @db.Text
  consent    Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

