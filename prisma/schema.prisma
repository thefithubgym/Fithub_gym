datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MemberType {
  SINGLE
  COUPLE
}

enum PaymentMethod {
  CASH
  UPI
}

enum MembershipStatus {
  ACTIVE
  UPCOMING
  EXPIRED
  INACTIVE
}

enum NotificationType {
  EXPIRY_REMINDER
  RECEIPT
  BROADCAST
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model Member {
  id               String            @id @default(uuid()) @db.Uuid
  firstName        String
  lastName         String
  phone            String            @unique
  gender           Gender
  email            String?
  dateOfBirth      DateTime?
  address          String?
  emergencyContact String?
  emergencyPhone   String?
  notes            String?
  avatarUrl        String?
  isDeleted        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  // Relationships
  memberships      Membership[]
  notifications    NotificationLog[]

  // Couple Group Membership
  coupleGroupId    String?           @db.Uuid
  coupleGroup      CoupleGroup?      @relation(fields: [coupleGroupId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([createdAt])
  @@map("members")
}

model CoupleGroup {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())

  // Relationships
  members     Member[]
  memberships Membership[]

  @@map("couple_groups")
}

model MembershipPlan {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  memberType     MemberType
  durationMonths Int
  price          Decimal      @db.Decimal(10, 2)
  isActive       Boolean      @default(true)
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]

  @@map("membership_plans")
}

model Membership {
  id                String            @id @default(uuid()) @db.Uuid
  memberId          String            @db.Uuid
  member            Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  coupleGroupId     String?           @db.Uuid
  coupleGroup       CoupleGroup?      @relation(fields: [coupleGroupId], references: [id], onDelete: SetNull)
  membershipPlanId  String?           @db.Uuid
  membershipPlan    MembershipPlan?   @relation(fields: [membershipPlanId], references: [id], onDelete: SetNull)
  customPlanName    String?
  amount            Decimal           @db.Decimal(10, 2)
  registrationFee   Decimal           @default(0.00) @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  paymentReference  String?
  startDate         DateTime
  endDate           DateTime
  status            MembershipStatus  @default(ACTIVE)
  remarks           String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([memberId])
  @@index([status])
  @@index([endDate])
  @@index([status, endDate])
  @@map("memberships")
}

model NotificationLog {
  id             String           @id @default(uuid()) @db.Uuid
  memberId       String           @db.Uuid
  member         Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type           NotificationType
  templateName   String?
  messagePreview String
  deliveryStatus DeliveryStatus   @default(PENDING)
  sentAt         DateTime         @default(now())
  createdAt      DateTime         @default(now())

  @@index([memberId])
  @@map("notification_logs")
}

model Settings {
  id               String   @id @default(uuid()) @db.Uuid
  gymName          String   @default("The FitHub Gym")
  registrationFee  Decimal  @default(200.00) @db.Decimal(10, 2)
  whatsappEnabled  Boolean  @default(false)
  whatsappPhoneId  String?
  whatsappToken    String?
  businessId       String?
  timezone         String   @default("Asia/Kolkata")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("settings")
}
